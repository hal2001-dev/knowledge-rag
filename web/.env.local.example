# Knowledge RAG NextJS — 환경 변수 템플릿
# 실제 값은 .env.local (gitignored)에 작성하고 이 파일은 commit 함.

# Clerk (https://dashboard.clerk.com → Application → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
# (선택) webhook 도입 시
# CLERK_WEBHOOK_SECRET=whsec_xxxx

# Clerk 인증 후 리다이렉트 (기본 / = 채팅 페이지)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# FastAPI 백엔드 (same-origin 프록시 — next.config.ts의 rewrites로 /api/* → INTERNAL_API_URL 전달)
# 브라우저는 접속한 도메인(localhost / Tailscale IP / reverse proxy 도메인) 그대로 /api/*만 호출 → CORS preflight 0
NEXT_PUBLIC_API_BASE_URL=/api
# (선택) Next dev/prod 서버 측 백엔드 실주소. 기본 http://localhost:8000
# INTERNAL_API_URL=http://localhost:8000

# 앱 표시 이름
NEXT_PUBLIC_APP_NAME=Knowledge RAG

# 인증 토글 (ADR-030)
# Phase 1: false 기본 — middleware는 통과만, FastAPI 미들웨어가 LAN/localhost는 'admin' 자동 부여
# Phase 2: true 전환 — Clerk JWT 검증 + 보호 라우트(/, /chat, /library) 비로그인 접근 차단
AUTH_ENABLED=false
