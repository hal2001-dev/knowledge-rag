# OpenAI (embedding + LLM legacy fallback)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.0

# LLM 백엔드 토글 (ADR-014) — openai | glm | custom (전부 OpenAI 호환)
# 빈 값은 backend별 기본값 사용 (openai→gpt-4o-mini, glm→glm-4-flash)
LLM_BACKEND=openai
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=

# Embedding 백엔드 토글 (ADR-016, TASK-002) — openai | bge-m3
# openai: text-embedding-3-small(1536-d, 과금). bge-m3: BAAI/bge-m3(1024-d, 로컬, 다국어)
# 변경 시 Qdrant 컬렉션 재생성 필요 → python pipeline/rebuild_index.py
EMBEDDING_BACKEND=openai
EMBEDDING_MODEL_NAME=
EMBEDDING_WARMUP=false

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# PostgreSQL
POSTGRES_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# 앱 설정
UPLOAD_DIR=./data/uploads
MARKDOWN_DIR=./data/markdown
DEFAULT_TOP_K=3
DEFAULT_INITIAL_K=20
DEFAULT_SCORE_THRESHOLD=0.7
MAX_UPLOAD_SIZE_MB=200
LOG_LEVEL=INFO

# 후속 질문 제안 (TASK-007) — 답변 후 자동 추천 질문 N개
SUGGESTIONS_ENABLED=true
SUGGESTIONS_COUNT=3

# 빈 채팅 인덱스 요약 카드 (TASK-008)
INDEX_OVERVIEW_ENABLED=true

# Reranker — flashrank(영어 MARCO, 빠름) | bge-m3(다국어, ~570MB, 로드 30~60초)
RERANKER_BACKEND=bge-m3
RERANKER_MODEL_NAME=
RERANKER_WARMUP=true

# LangSmith (선택) — https://smith.langchain.com 에서 API 키 발급
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=knowledge-rag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
